# ─────────────────────────────────────────────────────────────────────────
# FreshHub storefront (Next.js) environment
# Copy to `.env.local` and fill in.
# ─────────────────────────────────────────────────────────────────────────

# Medusa backend (required). The publishable key is validated at build time.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxx
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Storefront defaults
NEXT_PUBLIC_DEFAULT_REGION=ph
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NODE_ENV=development

# Stripe (optional — only if card payments are enabled)
NEXT_PUBLIC_STRIPE_KEY=

# Medusa Cloud S3 (optional — only for Medusa Cloud deployments; used by
# next.config.js to allow remote product images)
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Passwordless OTP sign-in (server-only secret). Used to derive each customer's
# internal Medusa credential. Keep it stable and secret — rotating it forces all
# customers to re-register. Generate with: openssl rand -hex 32
MFH_OTP_SECRET=

# Transactional email for OTP delivery (prod-required for sign-in/sign-up).
# Same Resend account as apps/backend (Phase B) — one key powers all email.
# Without it, OTP codes are only shown in the dev UI / server console in dev
# and sign-in fails in production. EMAIL_FROM must be a verified sender on
# your Resend account; it defaults to Resend's onboarding sender, which only
# delivers to the account owner's address.
RESEND_API_KEY=
EMAIL_FROM=

# Google sign-in (optional). Create an OAuth 2.0 Client ID (type "Web
# application") in Google Cloud Console and add
#   <NEXT_PUBLIC_BASE_URL>/api/auth/google/callback
# as an authorized redirect URI. The button stays hidden until both are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only needed when the public URL differs from what the server sees (e.g.
# behind a tunnel/proxy). Defaults to <request origin>/api/auth/google/callback
GOOGLE_REDIRECT_URI=
