# ─────────────────────────────────────────────────────────────────────────
# FreshHub backend (Medusa) environment
# Copy to `.env` and fill in. Values marked (prod-required) MUST be set in
# production — the server refuses to boot without them (see medusa-config.ts).
# ─────────────────────────────────────────────────────────────────────────

# Database (prod-required)
DATABASE_URL=postgres://user:password@localhost:5432/medusa-freshhub
DB_NAME=medusa-backend

# Redis (prod-required). Backs the event bus, cache, workflow engine, and
# distributed locks. Without it Medusa falls back to in-memory implementations
# that drop events on restart and cannot scale beyond one instance.
REDIS_URL=redis://localhost:6379

# Secrets (prod-required). Generate strong unique values:
#   openssl rand -base64 32
# The server rejects the literal "supersecret" in production.
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# CORS — comma-separated allowed origins
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# File storage / S3 (prod-required). Without these, uploads use the local disk,
# which is ephemeral and per-instance — seller photos would vanish on redeploy.
# Works with AWS S3 or any S3-compatible store (Cloudflare R2, MinIO, …).
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL files are served from (e.g. https://<bucket>.s3.<region>.amazonaws.com)
S3_FILE_URL=
# Optional: custom endpoint for S3-compatible providers
S3_ENDPOINT=
# Optional: set to any value to force path-style addressing (MinIO/R2)
S3_FORCE_PATH_STYLE=

# Transactional email (Phase B) — Resend. Leave RESEND_API_KEY unset to
# disable sending (emails are logged + recorded but not delivered).
RESEND_API_KEY=
# Verified sender, e.g. "Mindanao Fresh Hub <no-reply@yourdomain.ph>".
# Defaults to Resend's onboarding sender (delivers only to the account owner).
EMAIL_FROM=

# Rider-app "Sign in with Google" (/rider/auth/google/*). Same OAuth client as
# the storefront — also add
#   <backend origin>/rider/auth/google/callback
# (e.g. http://localhost:9000/rider/auth/google/callback) as an authorized
# redirect URI in Google Cloud Console. The button errors with "not set up
# yet" until both are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only needed when the public URL differs from what the server sees (e.g.
# behind a tunnel/proxy). Defaults to <request origin>/rider/auth/google/callback
GOOGLE_RIDER_REDIRECT_URI=
